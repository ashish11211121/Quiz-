<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us | Quizzard</title>
    <link rel="shortcut icon" href="/images/logo.png" type="image/x-icon">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background: #0f172a;
            color: #f1f5f9;
        }
        .glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .hero-gradient {
            background: radial-gradient(circle at 50% 50%, rgba(59, 130, 246, 0.1) 0%, rgba(15, 23, 42, 0) 70%);
        }
        .nav-link {
            position: relative;
            transition: all 0.3s ease;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: -4px;
            left: 0;
            background: #60a5fa;
            transition: width 0.3s ease;
        }
        .nav-link:hover::after {
            width: 100%;
        }
    </style>
</head>
<body class="min-h-screen">
    <div class="hero-gradient absolute inset-0 z-0 pointer-events-none"></div>

    <!-- Navbar -->
    <nav class="glass sticky top-0 w-full z-50 px-8 py-4 flex justify-between items-center relative">
        <div class="flex items-center gap-4">
            <img src="/images/logo.png" alt="logo" class="w-10 h-10">
            <span class="text-xl font-bold bg-gradient-to-r from-white to-slate-400 bg-clip-text text-transparent">Quizzard</span>
        </div>
        <div class="hidden md:flex gap-8 items-center font-medium">
            <a href="/" class="nav-link text-slate-300 hover:text-white">Home</a>
            <a href="/landing" class="nav-link text-slate-300 hover:text-white">Quizzes</a>
            <a href="/about" class="nav-link text-white">About</a>
            <a href="/contact" class="nav-link text-slate-300 hover:text-white">Contact</a>
        </div>
        <div class="flex gap-4">
            <a href="/login" class="px-5 py-1.5 rounded-full border border-slate-700 hover:bg-white/5 transition-all text-sm">Sign In</a>
        </div>
    </nav>

    <main class="relative z-10 max-w-6xl mx-auto px-6 py-20">
        <!-- Hero Section -->
        <div class="text-center mb-32">
            <h1 class="text-6xl md:text-7xl font-bold tracking-tight mb-8">
                The Future of <br>
                <span class="bg-gradient-to-r from-blue-400 to-indigo-500 bg-clip-text text-transparent">Interactive Learning</span>
            </h1>
            <p class="text-xl text-slate-400 max-w-3xl mx-auto leading-relaxed">
                At Quizzard, we believe knowledge shouldn't just be consumed—it should be an adventure. 
                We're building a platform where curiosity meets competition.
            </p>
        </div>

        <!-- Mission & Vision -->
        <div class="grid md:grid-cols-2 gap-12 mb-32">
            <div class="glass p-10 rounded-[2.5rem]">
                <div class="w-14 h-14 bg-blue-500/20 rounded-2xl flex items-center justify-center mb-8">
                    <svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </div>
                <h2 class="text-3xl font-bold mb-6">Our Mission</h2>
                <p class="text-slate-400 leading-relaxed text-lg">
                    To ignite curiosity and empower minds through interactive learning. We break down knowledge barriers with diverse quizzes, turning each question into an exploration of the unknown.
                </p>
            </div>

            <div class="glass p-10 rounded-[2.5rem]">
                <div class="w-14 h-14 bg-indigo-500/20 rounded-2xl flex items-center justify-center mb-8">
                    <svg class="w-8 h-8 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                </div>
                <h2 class="text-3xl font-bold mb-6">Our Vision</h2>
                <p class="text-slate-400 leading-relaxed text-lg">
                    To redefine the learning experience by creating a global hub where curiosity knows no bounds. We aspire to be a catalyst for a world where knowledge is a lifelong adventure.
                </p>
            </div>
        </div>

        <!-- Team Section Mock -->
        <div class="text-center">
            <h2 class="text-4xl font-bold mb-16">Meet the Visionaries</h2>
            <div class="flex flex-wrap justify-center gap-12">
                <div class="text-center group">
                    <div class="w-32 h-32 rounded-full bg-slate-800 mx-auto mb-6 border-2 border-transparent group-hover:border-blue-500 transition-all overflow-hidden shadow-xl">
                         <div class="w-full h-full bg-gradient-to-br from-blue-500 to-indigo-600 opacity-50"></div>
                    </div>
                    <h3 class="text-xl font-bold">Ashish</h3>
                    <p class="text-slate-500">Founder & CEO</p>
                </div>
                <div class="text-center group">
                    <div class="w-32 h-32 rounded-full bg-slate-800 mx-auto mb-6 border-2 border-transparent group-hover:border-blue-500 transition-all overflow-hidden shadow-xl">
                        <div class="w-full h-full bg-gradient-to-br from-indigo-500 to-purple-600 opacity-50"></div>
                    </div>
                    <h3 class="text-xl font-bold">Anuj</h3>
                    <p class="text-slate-500">Co-Founder & CTO</p>
                </div>
            </div>
        </div>
    </main>

    <footer class="mt-20 py-12 border-t border-white/5 text-center text-slate-500">
        <p>© 2026 Quizzard Learning Platform. All rights reserved.</p>
    </footer>
</body>
</html>
