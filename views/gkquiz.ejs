<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz | Quizzard</title>
    <link rel="shortcut icon" href="/images/logo.png" type="image/x-icon">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta2/css/all.min.css" />
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background: #0f172a;
            color: #f1f5f9;
        }
        .glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .quiz-option {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .quiz-option:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(59, 130, 246, 0.5);
            transform: translateX(8px);
        }
        .quiz-option.selected {
            background: #3b82f6;
            border-color: #60a5fa;
            color: white;
            box-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
        }
        .hero-gradient {
            background: radial-gradient(circle at 50% 50%, rgba(59, 130, 246, 0.1) 0%, rgba(15, 23, 42, 0) 70%);
        }
        .progress-bar {
            height: 4px;
            background: #3b82f6;
            transition: width 0.4s ease;
        }
        @keyframes slideIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-slide {
            animation: slideIn 0.3s ease-out forwards;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4 md:p-8">
    <div class="hero-gradient absolute inset-0 z-0 pointer-events-none"></div>

    <div class="relative z-10 w-full max-w-2xl">
        <div class="glass rounded-[2.5rem] overflow-hidden shadow-2xl">
            <!-- Header -->
            <div class="px-8 py-6 border-b border-white/10 flex justify-between items-center bg-white/5">
                <div class="flex items-center gap-4">
                    <a href="/landing" class="p-2 hover:bg-white/10 rounded-xl transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    </a>
                    <h1 class="text-xl font-bold">Challenge Your Mind</h1>
                </div>
                <div class="flex items-center gap-2 bg-blue-500/20 px-4 py-1.5 rounded-full">
                    <span id="correct-score" class="font-bold text-blue-400">0</span>
                    <span class="text-blue-400/50">/</span>
                    <span id="total-question" class="font-bold text-blue-400">0</span>
                </div>
            </div>

            <!-- Quiz Content -->
            <div class="p-8 md:p-12">
                <div id="quiz-body" class="animate-slide">
                    <h2 id="question" class="text-2xl md:text-3xl font-bold leading-tight mb-8">
                        <!-- Question injected here -->
                    </h2>

                    <ul class="quiz-options space-y-4">
                        <!-- Options injected here -->
                    </ul>
                </div>

                <!-- Result area -->
                <div id="result" class="mt-8 text-center min-h-[60px]">
                    <!-- Feedback injected here -->
                </div>
            </div>

            <!-- Footer -->
            <div class="px-8 py-6 border-t border-white/10 flex justify-between items-center bg-white/5">
                <button type="button" id="check-answer" class="px-8 py-3.5 bg-blue-500 hover:bg-blue-600 text-white font-bold rounded-2xl transition-all shadow-lg shadow-blue-500/25 active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed">
                    Submit Answer
                </button>
                <button type="button" id="play-again" class="hidden px-8 py-3.5 bg-slate-700 hover:bg-slate-600 text-white font-bold rounded-2xl transition-all">
                    Play Again
                </button>
            </div>
        </div>

        <p class="text-center mt-8 text-slate-500 text-sm">
            Press <kbd class="px-2 py-1 bg-slate-800 rounded border border-slate-700">Enter</kbd> to submit
        </p>
    </div>

    <script src="/javascripts/quiz-<%= foo %>.js"></script>
    <script>
        // Update JS to handle Tailwind classes for selection
        const observer = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
                if (mutation.type === 'childList') {
                    const options = document.querySelectorAll('.quiz-options li');
                    options.forEach(opt => {
                        opt.className = 'quiz-option px-6 py-4 rounded-2xl cursor-pointer flex items-center gap-4 font-medium text-lg';
                        opt.addEventListener('click', () => {
                            options.forEach(o => o.classList.remove('selected'));
                            opt.classList.add('selected');
                        });
                    });
                }
            });
        });
        observer.observe(document.querySelector('.quiz-options'), { childList: true });
    </script>
</body>
</html>