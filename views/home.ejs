<!doctype html>
<html>

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
  <title>Quizzard | Unleash Your Wisdom</title>
  <link rel="shortcut icon" href="/images/logo.png" type="image/x-icon">
  <style>
    body {
      font-family: 'Outfit', sans-serif;
      background: #0f172a;
      overflow-x: hidden;
    }

    .glass {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .hero-gradient {
      background: radial-gradient(circle at 50% 50%, rgba(59, 130, 246, 0.15) 0%, rgba(15, 23, 42, 0) 70%);
    }

    .nav-link {
      position: relative;
      transition: all 0.3s ease;
    }

    .nav-link::after {
      content: '';
      position: absolute;
      width: 0;
      height: 2px;
      bottom: -4px;
      left: 0;
      background: #60a5fa;
      transition: width 0.3s ease;
    }

    .nav-link:hover::after {
      width: 100%;
    }

    .btn-premium {
      background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .btn-premium:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.4);
    }

    .dropdown-content {
      display: none;
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(15, 23, 42, 0.95);
      backdrop-filter: blur(20px);
      min-width: 200px;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
      z-index: 1000;
      padding: 8px;
    }

    .dropdown:hover .dropdown-content {
      display: block;
      animation: fadeIn 0.2s ease-out;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateX(-50%) translateY(10px); }
      to { opacity: 1; transform: translateX(-50%) translateY(0); }
    }
  </style>
</head>

<body class="text-slate-200">
  <div class="hero-gradient absolute inset-0 z-0 pointer-events-none"></div>
  
  <div class="main relative z-10 min-h-screen flex flex-col">
    <!-- Navbar -->
    <nav class="glass sticky top-0 w-full z-50 px-8 py-4 flex justify-between items-center">
      <div class="flex items-center gap-4">
        <img src="/images/logo.png" alt="logo" class="w-12 h-12 drop-shadow-lg">
        <span class="text-2xl font-bold tracking-tight bg-gradient-to-r from-white to-slate-400 bg-clip-text text-transparent">Quizzard</span>
      </div>

      <div class="hidden md:flex gap-8 items-center font-medium">
        <a href="/" class="nav-link text-slate-300 hover:text-white">Home</a>
        <a href="/landing" class="nav-link text-slate-300 hover:text-white">Quizzes</a>
        <div class="dropdown relative group">
          <button class="nav-link text-slate-300 hover:text-white flex items-center gap-1">
            Categories
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div class="dropdown-content">
            <a href="/sciencequiz" class="block px-4 py-2 hover:bg-white/5 rounded-lg transition-colors">Science</a>
            <a href="/historyquiz" class="block px-4 py-2 hover:bg-white/5 rounded-lg transition-colors">History</a>
            <a href="/sportsquiz" class="block px-4 py-2 hover:bg-white/5 rounded-lg transition-colors">Sports</a>
            <a href="/gkquiz" class="block px-4 py-2 hover:bg-white/5 rounded-lg transition-colors">General Knowledge</a>
          </div>
        </div>
        <a href="/about" class="nav-link text-slate-300 hover:text-white">About</a>
        <a href="/contact" class="nav-link text-slate-300 hover:text-white">Contact</a>
      </div>

      <div class="flex gap-4">
        <a href="/login" class="px-6 py-2 rounded-full border border-slate-700 hover:bg-white/5 transition-all">Sign In</a>
        <a href="/register" class="btn-premium px-6 py-2 rounded-full font-semibold text-white">Join Free</a>
      </div>
    </nav>

    <!-- Hero Content -->
    <main class="flex-grow flex flex-col justify-center items-center px-6 text-center mt-[-80px]">
      <div class="max-w-4xl space-y-8">
        <div class="inline-block px-4 py-1.5 glass rounded-full text-sm font-medium text-blue-400 mb-4">
          ✨ New: Science & Space Quizzes Live
        </div>
        
        <h1 class="text-6xl md:text-8xl font-bold tracking-tighter leading-none text-white">
          Unleash Your Inner <br>
          <span class="bg-gradient-to-r from-blue-400 to-indigo-500 bg-clip-text text-transparent">Wizard of Wisdom</span>
        </h1>
        
        <p class="text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed">
          Embark on a journey of knowledge exploration with our extensive collection of interactive quizzes. Challenge yourself and climb the leaderboard.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center pt-8">
          <a href="/login" class="btn-premium px-10 py-5 rounded-2xl text-2xl font-bold flex items-center gap-3">
            Start Learning
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
          </a>
          <div class="flex items-center gap-4 text-slate-500 font-medium">
            <div class="flex -space-x-3">
              <div class="w-10 h-10 rounded-full border-2 border-slate-900 bg-slate-800"></div>
              <div class="w-10 h-10 rounded-full border-2 border-slate-900 bg-slate-700"></div>
              <div class="w-10 h-10 rounded-full border-2 border-slate-900 bg-slate-600"></div>
            </div>
            <span>Join 2,000+ Students</span>
          </div>
        </div>
      </div>
    </main>

    <!-- Footer-ish -->
    <div class="p-8 flex justify-center gap-8 opacity-50 grayscale hover:grayscale-0 transition-all">
       <a href="https://facebook.com" class="hover:text-blue-400 transition-colors">Facebook</a>
       <a href="https://instagram.com" class="hover:text-pink-400 transition-colors">Instagram</a>
       <a href="https://twitter.com" class="hover:text-blue-300 transition-colors">Twitter</a>
    </div>
  </div>
</body>

</html>