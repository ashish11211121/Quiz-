<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <title>Explore Quizzes | Quizzard</title>
    <link rel="shortcut icon" href="/images/logo.png" type="image/x-icon">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background: #0f172a;
            color: white;
        }
        .glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .quiz-card {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .quiz-card:hover {
            transform: translateY(-12px) scale(1.02);
            border-color: rgba(59, 130, 246, 0.5);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        .fade-in {
            animation: fadeIn 0.6s ease-out forwards;
            opacity: 0;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="min-h-screen p-8 md:p-16">
    <div class="max-w-7xl mx-auto">
        <header class="mb-16 flex justify-between items-center fade-in" style="animation-delay: 0.1s">
            <div>
                <h1 class="text-5xl font-bold tracking-tight mb-2">Explore <span class="text-blue-400">Categories</span></h1>
                <p class="text-slate-400 text-lg">Choose a topic and test your knowledge</p>
            </div>
            <a href="/" class="glass px-6 py-2 rounded-full hover:bg-white/5 transition-colors">Back Home</a>
        </header>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <!-- GK Quiz -->
            <a href="/gkquiz" class="fade-in" style="animation-delay: 0.2s">
                <div class="quiz-card glass rounded-3xl overflow-hidden h-full flex flex-col">
                    <div class="h-48 overflow-hidden">
                        <img src="/images/general-knowledge-quiz.webp" class="w-full h-full object-cover grayscale-[0.2] hover:grayscale-0 transition-all duration-500">
                    </div>
                    <div class="p-6">
                        <h2 class="text-2xl font-bold mb-2">General Knowledge</h2>
                        <p class="text-slate-400 text-sm mb-4">Mixed topics from history, politics, and more.</p>
                        <span class="text-blue-400 font-semibold flex items-center gap-2">Start Quiz <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></span>
                    </div>
                </div>
            </a>

            <!-- Science Quiz -->
            <a href="/sciencequiz" class="fade-in" style="animation-delay: 0.3s">
                <div class="quiz-card glass rounded-3xl overflow-hidden h-full flex flex-col">
                    <div class="h-48 overflow-hidden">
                        <img src="/images/science quiz.webp" class="w-full h-full object-cover grayscale-[0.2] hover:grayscale-0 transition-all duration-500">
                    </div>
                    <div class="p-6">
                        <h2 class="text-2xl font-bold mb-2">Science</h2>
                        <p class="text-slate-400 text-sm mb-4">Explore the wonders of physics, biology, and space.</p>
                        <span class="text-blue-400 font-semibold flex items-center gap-2">Start Quiz <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></span>
                    </div>
                </div>
            </a>

            <!-- History Quiz -->
            <a href="/historyquiz" class="fade-in" style="animation-delay: 0.4s">
                <div class="quiz-card glass rounded-3xl overflow-hidden h-full flex flex-col">
                    <div class="h-48 overflow-hidden">
                        <img src="/images/history.png" class="w-full h-full object-cover grayscale-[0.2] hover:grayscale-0 transition-all duration-500">
                    </div>
                    <div class="p-6">
                        <h2 class="text-2xl font-bold mb-2">History</h2>
                        <p class="text-slate-400 text-sm mb-4">Travel back in time to the world's greatest events.</p>
                        <span class="text-blue-400 font-semibold flex items-center gap-2">Start Quiz <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></span>
                    </div>
                </div>
            </a>

            <!-- Sports Quiz -->
            <a href="/sportsquiz" class="fade-in" style="animation-delay: 0.5s">
                <div class="quiz-card glass rounded-3xl overflow-hidden h-full flex flex-col">
                    <div class="h-48 overflow-hidden">
                        <img src="/images/sport.jpg" class="w-full h-full object-cover grayscale-[0.2] hover:grayscale-0 transition-all duration-500">
                    </div>
                    <div class="p-6">
                        <h2 class="text-2xl font-bold mb-2">Sports</h2>
                        <p class="text-slate-400 text-sm mb-4">Test your knowledge of teams, players, and games.</p>
                        <span class="text-blue-400 font-semibold flex items-center gap-2">Start Quiz <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></span>
                    </div>
                </div>
            </a>
        </div>
    </div>
</body>
</html>